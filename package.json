                         "react":  "19.2.4",
                         "react-dom":  "19.2.4"
                     },
    "devDependencies":  {
                            "@types/node":  "^20",
                            "@types/react":  "^19",
                            "@types/react-dom":  "^19",
                            "autoprefixer":  "10.4.21",
                            "eslint":  "^9",
                            "eslint-config-next":  "16.2.10",
                            "postcss":  "8.5.10",
                            "tailwindcss":  "^3.4.19",
                            "tsx":  "^4.19.0",
                            "typescript":  "^5"
                        },
    "packageManager":  "pnpm@9.0.0",
    "engines":  {
                    "node":  "\u003e=20.9.0"
                }
}