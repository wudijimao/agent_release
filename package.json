{
    "name":  "@bioagent/nextjs",
    "version":  "0.1.0",
    "private":  true,
    "browserslist":  [
                         "chrome 111",
                         "edge 111",
                         "firefox 111",
                         "safari 16.4"
                     ],
    "scripts":  {
                    "dev":  "next dev",
                    "build":  "corepack pnpm@9.0.0 --filter @bioagent/shared build \u0026\u0026 next build",
                    "start":  "next start",
                    "lint":  "eslint src next.config.ts",
                    "test":  "node --import tsx --test src/**/*.test.ts",
                    "release:check":  "corepack pnpm@9.0.0 --filter @bioagent/chatui styles:check \u0026\u0026 corepack pnpm@9.0.0 --filter @bioagent/shared build \u0026\u0026 corepack pnpm@9.0.0 test \u0026\u0026 corepack pnpm@9.0.0 lint \u0026\u0026 corepack pnpm@9.0.0 build"
                },
    "dependencies":  {
                         "@bioagent/chatui":  "workspace:*",
