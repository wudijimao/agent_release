{
  "name": "@bioagent/chatui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "tailwind.config.ts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/style.css",
    "./tailwind-config": "./tailwind.config.ts",
    "./showcase": {
      "types": "./dist/showcase/index.d.ts",
      "import": "./dist/showcase.js"
    }
  },
  "scripts": {
    "dev": "vite --port 5174",
    "build": "npm run styles:check && vite build && tsc -p tsconfig.build.json",
    "styles:check": "node .codex/skills/check-chatui-styles/scripts/check-theme-colors.mjs && node .codex/skills/check-chatui-styles/scripts/check-prototype-boundaries.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "antd": "^6.4.5",
    "classnames": "^2.3.2",
    "dayjs": "^1.11.21",
    "highlight.js": "11.11.1",
    "katex": "0.16.47",
    "lucide-react": "1.21.0",
    "mermaid": "11.16.0",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "rehype-katex": "7.0.1",
    "remark-emoji": "5.0.2",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0",
    "vite": "7.3.6"
  }
}
